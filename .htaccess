# ============================================================
# LUXE SHOP — Apache .htaccess
# ============================================================

Options -Indexes
Options -MultiViews
# 0. prevent the leakage of our php version
Header unset X-Powered_by

RewriteEngine On
# 1. Redirect empty requests to the subfolder
RewriteRule ^$ public/index.php [L]

# ---- Force HTTPS (uncomment in production) ----
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ---- Remove www (uncomment if needed) ----
# RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
# RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# ---- Protect sensitive files ----
<FilesMatch "\.(env|sql|log|sh|git|DS_Store)$">
    Require all denied
</FilesMatch>

# Block access to includes directory directly
RewriteRule ^includes/ - [F,L]
RewriteRule ^admin/includes/ - [F,L]

# ---- Custom 404 ----
ErrorDocument 404 /404.php

# ---- Security Headers ----
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ---- Gzip Compression ----
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript text/plain
</IfModule>

# ---- Browser Caching ----
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg  "access plus 1 month"
    ExpiresByType image/png   "access plus 1 month"
    ExpiresByType image/webp  "access plus 1 month"
    ExpiresByType text/css    "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>